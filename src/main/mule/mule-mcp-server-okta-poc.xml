	<flow name="mcp-dual-auth-session-flow">
        
        <mcp:on-new-session-listener doc:name="MCP Server - On New Session Listener" config-ref="MCP_Server">
            <mcp:rejection rejectWithStatusCode="#[vars.httpStatus]" rejectWithMessage="#[vars.errorMessage]" />
        </mcp:on-new-session-listener>
        
        <logger level="INFO" doc:name="Log Incoming Request" message="Incoming MCP Streamable HTTP Request received."/>
        
        <set-variable variableName="jwtToken" value="#[(payload.additionalProperties['authorization'] default '') replace 'Bearer ' with '']" doc:name="Extract Bearer Token" />
        <set-variable variableName="clientId" value="#[payload.additionalProperties['x-client-id'] default '']" doc:name="Extract Client ID" />
        <set-variable variableName="clientSecret" value="#[payload.additionalProperties['x-client-secret'] default '']" doc:name="Extract Client Secret" />

        <choice doc:name="Which Auth Method?">
            
            <when expression="#[not isEmpty(vars.jwtToken)]">
                <logger level="INFO" message="Auth Strategy: Introspecting Bearer Token via Okta..."/>
                <http:request method="POST" config-ref="Okta_Introspect_Config" path="/oauth2/default/v1/introspect" doc:name="Okta /introspect">
                    <http:body><![CDATA[#[%dw 2.0
output application/x-www-form-urlencoded
---
{
    "token": vars.jwtToken,
    "client_id": p('mule.okta.client_id'),
    "client_secret": p('mule.okta.client_secret')
}]]]></http:body>
                </http:request>
                
                <choice doc:name="Is Token Active?">
                    <when expression="#[payload.active == true]">
                        <logger level="INFO" message="SUCCESS: MCP Session Established. Token verified." />
                    </when>
                    <otherwise>
						<ee:transform doc:name="Transform Message" doc:id="83f0df63-bcb8-452b-892d-762e62974874" >
							<ee:message >
							</ee:message>
							<ee:variables >
								<ee:set-variable variableName="httpStatus" ><![CDATA[401]]></ee:set-variable>
								<ee:set-variable variableName="errorMessage" ><![CDATA["Bearer Token is inactive or expired."]]></ee:set-variable>
							</ee:variables>
						</ee:transform>
                    
</otherwise>
                </choice>
            </when>

            <when expression="#[not isEmpty(vars.clientId) and not isEmpty(vars.clientSecret)]">
                <logger level="INFO" message="Auth Strategy: Validating Direct Credentials via Okta..."/>
                <try doc:name="Try Generating Token">
                    <http:request method="POST" config-ref="Okta_Introspect_Config" path="/oauth2/default/v1/token" doc:name="Okta /token">
                        <http:body><![CDATA[#[%dw 2.0
output application/x-www-form-urlencoded
---
{
    "grant_type": "client_credentials",
    "scope": "mcp.invoke",
    "client_id": vars.clientId,
    "client_secret": vars.clientSecret
}]]]></http:body>
                    </http:request>
                    
                    <logger level="INFO" message="SUCCESS: MCP Session Established. Direct Credentials verified."/>
					<error-handler>
						<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="d2e9c1c6-b304-4985-aa24-3f04d4c1bf43" type="HTTP:UNAUTHORIZED, HTTP:BAD_REQUEST">
							<ee:transform doc:name="Transform Message" doc:id="648818ee-3e06-4274-b550-77248072bd7a" >
								<ee:message />
								<ee:variables >
									<ee:set-variable variableName="httpStatus" ><![CDATA[401]]></ee:set-variable>
									<ee:set-variable variableName="errorMessage" ><![CDATA["Invalid Client ID or Secret."]]></ee:set-variable>
								</ee:variables>
							</ee:transform>
						</on-error-continue>

                    </error-handler>
                
</try>
            </when>
			<otherwise>
				<ee:transform doc:name="Transform Message" doc:id="0f2de996-d32e-456b-abd8-46253c2465bd" >
					<ee:message />
					<ee:variables >
						<ee:set-variable variableName="httpStatus" ><![CDATA[401]]></ee:set-variable>
						<ee:set-variable variableName="errorMessage" ><![CDATA["Request blocked. Missing Authorization or x-client-id headers."]]></ee:set-variable>
					</ee:variables>
				</ee:transform>

            </otherwise>
        
</choice>

    </flow>

</mule>
